# =============================================================================
# Spherix – Konfiguration
# Kopiere diese Datei als .env und passe die Werte an.
# =============================================================================

# ── Datenbank & Cache (intern, nicht ändern) ──────────────────────────────────
DATABASE_URL=postgresql://musicserver:musicserver@localhost:5432/musicserver
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Zufälliger geheimer Schlüssel für Sessions — bitte ändern!
SESSION_SECRET=change-me-to-a-random-secret

# Öffentliche URL — die Adresse, unter der Spherix im Browser erreichbar ist.
# Wird für OAuth-Callbacks (z.B. Last.fm) benötigt.
# Beispiel: PUBLIC_URL=http://192.168.1.100:80
PUBLIC_URL=

# ── Datenpersistenz ───────────────────────────────────────────────────────────
# DATA_PATH: Wo Spherix seine Daten speichert (PostgreSQL, Redis, Cover-Bilder).
# Standard: ./data  (neben der docker-compose.yml – wird automatisch angelegt)
# Für Unraid:   DATA_PATH=/mnt/user/appdata/spherix
# Für TrueNAS:  DATA_PATH=/mnt/tank/appdata/spherix
# Für Synology: DATA_PATH=/volume1/docker/spherix
#
# WICHTIG: Dieses Verzeichnis NIEMALS löschen – alle Daten gehen verloren!
#          Kein "docker compose down -v" verwenden (löscht benannte Volumes).
DATA_PATH=./data

# ── Medienpfade ────────────────────────────────────────────────────────────────
# Host-Pfade zu den Medienbibliotheken (schreibgeschützt eingebunden)
MUSIC_DIR=/pfad/zu/deiner/musik
VIDEO_DIR=/pfad/zu/deinen/videos
AUDIOBOOK_DIR=/pfad/zu/deinen/hoerbuechern

# Interne Container-Pfade (nicht ändern)
MUSIC_PATH=/music
VIDEO_PATH=/videos
AUDIOBOOK_PATH=/audiobooks

# ── Last.fm Scrobbling ────────────────────────────────────────────────────────
# API-Key und Secret von https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_API_SECRET=

# ── TMDb (The Movie Database) — Filmmetadaten ────────────────────────────────
# Kostenloser API-Key unter https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Frontend (nur für lokale Entwicklung relevant) ───────────────────────────
VITE_API_URL=http://localhost:3000/api
